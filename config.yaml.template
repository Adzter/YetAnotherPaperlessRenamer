paperless:
  url: "http://localhost:8000"
  token: "your-api-token-here"  # or set PAPERLESS_TOKEN env var

scanner_pattern: "^BRW\\d+"  # regex matching scanner default filenames

mode: "webhook"  # "once", "daemon", or "webhook"

webhook:
  port: 8080  # used in webhook mode only

scheduling:
  interval_minutes: 30  # used in daemon mode only

llm:
  provider: "ollama"  # "ollama" or "anthropic"

  ollama:
    url: "http://ollama-host:11434"
    model: "mistral:7b"  # recommended, pull with: ollama pull mistral:7b

  anthropic:
    api_key: ""  # or set ANTHROPIC_API_KEY env var
    model: "claude-haiku-4-5"

  max_content_chars: 3000  # first ~1 page of OCR text

logging:
  level: "INFO"
  file: ""  # leave empty to log to stdout only

dry_run: false
